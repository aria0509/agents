{
  "name": "agents",
  "version": "0.2.4",
  "description": "GUI for managing multiple Claude Code CLI accounts and sessions",
  "author": "Lucas",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "rebuild": "electron-rebuild -f -w node-pty",
    "postinstall": "electron-rebuild -f -w node-pty",
    "start": "electron-vite preview",
    "package": "electron-vite build && ( [ -f .env ] && . ./.env; electron-builder --mac )",
    "package:signonly": "electron-vite build && electron-builder --mac -c.mac.notarize=false"
  },
  "license": "ISC",
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "dependencies": {
    "electron-store": "^11.0.2",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron/rebuild": "^4.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "43.1.0",
    "electron-builder": "26.15.6",
    "electron-vite": "^5.0.0",
    "i18next": "^26.3.6",
    "lucide-react": "^1.24.0",
    "playwright-core": "^1.61.1",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.9",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "zustand": "^5.0.14"
  }
}
